<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Image Gallery</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #ece9e6, #ffffff);
        }

        h1 {
            text-align: center;
            padding: 20px;
            color: #333;
        }

        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 15px;
            padding: 20px;
        }

        .box {
            overflow: hidden;
            border-radius: 10px;
            position: relative;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .box img {
            width: 100%;
            height: 100%;
            transition: transform 0.5s ease, filter 0.5s ease;
        }

        /* Hover Effects */
        .box:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .box:hover img {
            transform: scale(1.2);
            filter: brightness(0.8);
        }

        /* Overlay */
        .box::after {
            content: "View";
            position: absolute;
            bottom: 10px;
            left: 10px;
            background: linear-gradient(45deg, #ff7e5f, #feb47b);
            color: white;
            padding: 5px 10px;
            border-radius: 5px;
            opacity: 0;
            transition: 0.4s;
        }

        .box:hover::after {
            opacity: 1;
        }
    </style>

</head>

<body>

    <h1>🌸 Image Gallery 🌸</h1>

    <div class="gallery">

        <div class="box">
            <img src="https://picsum.photos/300?1">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?2">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?3">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?4">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?5">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?6">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?7">
        </div>

        <div class="box">
            <img src="https://picsum.photos/300?8">
        </div>

    </div>

</body>
</html>
